# ============================================
# WikiAI Backend - Environment Variables
# Copy this file to .env and fill in values
# ============================================

# Server
NODE_ENV=development
PORT=3000
API_VERSION=v1

# JWT
JWT_SECRET=9f8sd7f98s7df98s7df98s7df98s7df98s7df
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# Database (MongoDB)
MONGODB_URI=mongodb://localhost:27017/wikiai_db

# Redis
REDIS_URL=redis://localhost:6380

# OpenAI (optional; current local AI path uses Ollama)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_CHAT_MODEL=gpt-4o

# Groq (optional)
GROQ_API_KEY=gsk_your_groq_api_key_here
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_EMBEDDING_MODEL=

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=qwen2.5:3b
OLLAMA_EMBEDDING_MODEL=qwen2.5:3b

# HuggingFace Embeddings
HUGGINGFACE_EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# YouTube Data API v3
YOUTUBE_API_KEY=AIzaSyAyMB525K4puh--ShFWj4J_EJ8VE02GjQg

# Email (Resend - https://resend.com)
RESEND_API_KEY=re_your-resend-api-key
FROM_EMAIL=noreply@wikiai.app

# AWS S3 (optional - for profile image uploads)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=wikiai-assets

# Rate Limiting
AI_RATE_LIMIT_PER_MINUTE=10
GLOBAL_RATE_LIMIT_PER_15MIN=200

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8081,exp://localhost:19000

# Logging
LOG_LEVEL=debug
